{
  "name": "@totvs-cloud/iam-sdk",
  "repository": {
    "url": "https://github.com/totvscloud-seginf/iam-sdk-js"
  },
  "version": "0.2.0",
  "description": "Framework-agnostic TypeScript SDK for TOTVS Cloud IAM.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  }
}
